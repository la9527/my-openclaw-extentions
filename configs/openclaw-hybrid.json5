// OpenClaw 하이브리드 LLM 라우팅 설정 예시
// 이 파일을 ~/.openclaw/openclaw.json 에 병합하여 사용
//
// 현재 권장 기준:
//   1. 기본 local 런타임은 LM Studio OpenAI 호환 endpoint 사용
//   2. 기본 local 모델은 lmstudio-community/LFM2-24B-A2B-MLX-4bit
//   3. 분류기는 local 우선 + timeout>=3s면 full, JSON/연결/HTTP 실패면 nano
//   4. 환경변수: export OPENAI_API_KEY=sk-...
{
  // ── 모델 프로바이더 ──────────────────────────────────────────
  // smart-router 가 LM Studio OpenAI 호환 API를 local 경로로 사용한다.
  "models": {
    "mode": "merge",
    "providers": {
      "lmstudio": {
        "baseUrl": "http://127.0.0.1:1235/v1",
        "apiKey": "lm-studio",
        "api": "openai-completions",
        "models": [
          {
            "id": "lmstudio-community/LFM2-24B-A2B-MLX-4bit",
            "name": "LFM2 24B A2B MLX 4bit (로컬 기본)",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 32768,
            "maxTokens": 8192
          }
        ]
      }
    }
  },

  // ── 에이전트 기본 설정 ─────────────────────────────────────
  "agents": {
    "defaults": {
      "compaction": {
        // 세션 요약 시 사용하는 모델 (smart-router/auto 대신 직접 지정)
        "model": "openai/gpt-5.4-mini-2026-03-17"
      },
      "model": {
        // smart-router/auto 를 primary로 설정하면
        // 복잡도에 따라 로컬↔외부 자동 라우팅
        "primary": "smart-router/auto",
        // 선택 사항: smart-router 자체 장애 시 직접 외부 LLM 사용
        "fallbacks": ["openai/gpt-5.4-mini-2026-03-17"]
      },
      "models": {
        "smart-router/auto": {},
        "smart-router/local": {},
        "smart-router/nano": {},
        "smart-router/mini": {},
        "smart-router/full": {},
        "lmstudio/lmstudio-community/LFM2-24B-A2B-MLX-4bit": {},
        "openai/gpt-5.4-mini-2026-03-17": {}
      }
    }
  },

  // ── 플러그인 설정 ──────────────────────────────────────────
  "plugins": {
    "entries": {
      "smart-router": {
        "enabled": true,
        "config": {
          // 로컬 LLM 설정 (LM Studio)
          "localProvider": "lmstudio",
          "localModel": "lmstudio-community/LFM2-24B-A2B-MLX-4bit",
          "localBaseUrl": "http://127.0.0.1:1235/v1",
          "localApi": "openai",
          // 외부 LLM 설정
          "remoteProvider": "openai",
          "nanoModel": "gpt-5.4-nano-2026-03-17",
          "miniModel": "gpt-5.4-mini-2026-03-17",
          "fullModel": "gpt-5.4-2026-03-05",
          "remoteBaseUrl": "https://api.openai.com/v1",
          "remoteApi": "openai-responses",
          // 이 수준 이상이면 외부 tier(nano/mini/full) 라우팅
          "threshold": "moderate",
          // 복잡도 평가는 LLM 분류 모델 사용 (rule 보다 정확)
          "evaluationMode": "llm",
          // llm 평가 모드에서 분류 모델은 local 경로 사용
          "evaluationLlmTarget": "local",
          // LLM 평가 타임아웃 (ms). timeout>=3s면 full fallback
          "evaluationTimeoutMs": 3000,
          "evaluationTimeoutRetryCount": 1,
          "evaluationTimeoutFallbackTarget": "nano",
          "streamFirstTokenTimeoutMs": 15000,
          "streamRetryOnFailure": true,
          // 응답 첫 줄에 선택된 모델 표시
          "showModelLabel": true,
          // local 라우팅 시 tool schema 제거
          "localForceNoTools": true,
          // local 상태가 나쁠 때 nano 로 1차 승격 허용
          "latencyAwareRouting": true
        }
      }
    }
  }
}
